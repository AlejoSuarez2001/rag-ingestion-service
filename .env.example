# BookStack API
BOOKSTACK_URL=https://docs.example.com
BOOKSTACK_TOKEN_ID=your_token_id
BOOKSTACK_TOKEN_SECRET=your_token_secret
BOOKSTACK_PAGE_SIZE=500

# Qdrant (same instance as hybrid-rag-backend)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals

# Embeddings
# ⚠️ This model MUST match the one used in hybrid-rag-backend for queries.
# Default: paraphrase-multilingual-mpnet-base-v2 → 768-dim vectors
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu   # use "cuda" if GPU is available

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
TIKTOKEN_ENCODING=cl100k_base

# State tracking
TRACKER_DB_PATH=ingestion_state.db

# Logging
LOG_LEVEL=INFO

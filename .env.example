# Auth / Keycloak
AUTH_CERTS=
AUTH_SERVER_ISSUER=
KEYCLOAK_CLIENTID=rag-ingestion-service
AUTH_VERIFY_SSL=false

# BookStack API
BOOKSTACK_URL=https://docs.example.com
BOOKSTACK_TOKEN_ID=your_token_id
BOOKSTACK_TOKEN_SECRET=your_token_secret

# Qdrant
QDRANT_HOST=qdrant-rag
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals

# Embeddings
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cuda

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
TIKTOKEN_ENCODING=cl100k_base

# State tracking (Postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag_ingestion
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# Logging
LOG_LEVEL=INFO

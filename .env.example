# BookStack API
BOOKSTACK_URL=https://docs.example.com
BOOKSTACK_TOKEN_ID=your_token_id
BOOKSTACK_TOKEN_SECRET=your_token_secret

# Qdrant
QDRANT_HOST=qdrant-rag
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals

# Embeddings
OLLAMA_BASE_URL=http://10.2.8.25:11434
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_BATCH_SIZE=32

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
TIKTOKEN_ENCODING=cl100k_base

# OCR de imágenes (corre local en el contenedor, CPU; no usa la VM de inferencia)
OCR_ENABLED=true
OCR_DOWNLOAD_TIMEOUT=15
OCR_TEXT_SCORE=0.8
OCR_BOX_THRESH=0.5
OCR_UNCLIP_RATIO=1.6
OCR_MAX_IMAGE_MB=10

# State tracking
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag_ingestion
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# Logging
LOG_LEVEL=INFO
